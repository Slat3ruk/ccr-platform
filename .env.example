# CrossCurrent Racing Platform — Environment Variables Template

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL connection string
# Format: postgres://user:password@host:port/database
# Options:
#   - Self-hosted on the VPS: postgres running on the same box (recommended)
#   - Managed: DigitalOcean Managed DB, AWS RDS, Neon, etc.
#   - Local dev: postgres://ccr_admin:password@localhost:5432/ccr_platform
DATABASE_URL=postgres://ccr_admin:changeme@localhost:5432/ccr_platform

# ============================================================================
# GOOGLE SHEETS (Benchmark Sync)
# ============================================================================

# Google Sheets API key (Cloud Console)
# https://console.cloud.google.com → Create project → Enable Sheets API → Create API key
GOOGLE_SHEETS_API_KEY=your-google-api-key-here

# Google Sheets ID (Ohne Speed LMU Laptimes)
# From URL: https://docs.google.com/spreadsheets/d/[THIS_ID]/edit
GOOGLE_SHEETS_ID=1vTN03UvJDm99byA6vQPZHKOCYVvfxLu1zkJAzdaKyROykzEKY2-Xl1rl1q5znZEf36m88dxMKsY2eaO

# ============================================================================
# NEXT.JS
# ============================================================================

# Public API URL (used by frontend for API calls)
# Development: http://localhost:3000
# Production: https://data.crosscurrentracing.com  (subdomain of the team site)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Environment
# Options: development, production
NODE_ENV=development

# ============================================================================
# LOCAL DEV AUTH BYPASS (src/middleware.ts) — never set on the server
# ============================================================================

# AUTH_DEV_MODE=1 skips the ccr-auth verification and authenticates every
# request as a fake local identity, so role-gated pages work on localhost
# (Discord OAuth can only complete against the real domain). It is DOUBLE
# gated: also requires a non-production build (NODE_ENV !== "production"), so
# a prod build can't even compile the branch in. Put it in .env.local
# (gitignored) — NEVER in the VPS environment or systemd unit.
AUTH_DEV_MODE=
# Role for the fake identity: driver | manager | admin (default admin)
AUTH_DEV_ROLE=

# ============================================================================
# OPTIONAL: Discord OAuth (Phase 2)
# ============================================================================

# Discord app credentials (create at discord.com/developers/applications)
# Leave blank for Phase 1 (no auth required)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback

# ============================================================================
# OPTIONAL: Monitoring & Logging (Phase 3)
# ============================================================================

# Sentry error tracking (optional)
SENTRY_DSN=

# Datadog API key (optional)
DATADOG_API_KEY=

